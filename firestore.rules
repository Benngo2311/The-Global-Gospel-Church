rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: prayers
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, max 2000 chars) - The prayer text
    //   - author: string (required, max 100 chars) - The author's name
    //   - email: string (optional, max 100 chars) - The author's email
    //   - phone: string (optional, max 50 chars) - The author's phone
    //   - prayedCount: number (required, >= 0) - Number of times prayed
    //   - timestamp: number (required) - Creation timestamp
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidPrayer(data) {
      return hasOnlyAllowedFields(['text', 'author', 'email', 'phone', 'prayedCount', 'timestamp']) &&
             isValidString('text', 1, 2000) &&
             isValidString('author', 1, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('phone', 0, 50) &&
             data.prayedCount is number && data.prayedCount >= 0 &&
             data.timestamp is number;
    }
    
    function isValidPrayerIncrement() {
      // Only allow updating prayedCount by exactly +1 or -1, and ensure it doesn't go below 0
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedCount']) &&
             (request.resource.data.prayedCount == resource.data.prayedCount + 1 || 
              request.resource.data.prayedCount == resource.data.prayedCount - 1) &&
             request.resource.data.prayedCount >= 0;
    }

    function isValidRepentance(data) {
      return hasOnlyAllowedFields(['text', 'author', 'email', 'phone', 'graceCount', 'timestamp']) &&
             isValidString('text', 1, 2000) &&
             isValidString('author', 1, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('phone', 0, 50) &&
             data.graceCount is number && data.graceCount >= 0 &&
             data.timestamp is number;
    }
    
    function isValidGraceIncrement() {
      // Only allow updating graceCount by exactly +1 or -1, and ensure it doesn't go below 0
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['graceCount']) &&
             (request.resource.data.graceCount == resource.data.graceCount + 1 || 
              request.resource.data.graceCount == resource.data.graceCount - 1) &&
             request.resource.data.graceCount >= 0;
    }

    function isValidCreation(data) {
      return hasOnlyAllowedFields(['category', 'title', 'author', 'content', 'audioUrl', 'imageUrl', 'videoUrl', 'timestamp', 'amenCount']) &&
             isValidString('category', 1, 50) &&
             (data.category == 'testimonies' || data.category == 'poems' || data.category == 'songs' || data.category == 'prophetic') &&
             isValidString('title', 1, 200) &&
             isValidString('author', 1, 100) &&
             isValidString('content', 1, 5000) &&
             isValidOptionalString('audioUrl', 0, 2000) &&
             isValidOptionalString('imageUrl', 0, 2000) &&
             isValidOptionalString('videoUrl', 0, 2000) &&
             data.timestamp is number &&
             (!('amenCount' in data) || (data.amenCount is number && data.amenCount >= 0));
    }

    function isValidCreationIncrement() {
      let oldAmenCount = 'amenCount' in resource.data ? resource.data.amenCount : 0;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amenCount']) &&
             (request.resource.data.amenCount == oldAmenCount + 1 || 
              request.resource.data.amenCount == oldAmenCount - 1) &&
             request.resource.data.amenCount >= 0;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khoatruy123@gmail.com" && request.auth.token.email_verified == true;
    }

    function isValidJourneyMedia(data) {
      return hasOnlyAllowedFields(['url', 'type', 'description', 'year', 'date', 'isTimeline', 'timestamp', 'author', 'category']) &&
             isValidString('url', 1, 2000) &&
             (data.type == 'image' || data.type == 'video') &&
             isValidOptionalString('description', 0, 2000) &&
             (!('year' in data) || (data.year is number && data.year >= 1900 && data.year <= 2100)) &&
             isValidOptionalString('date', 0, 20) &&
             (!('isTimeline' in data) || data.isTimeline is bool) &&
             data.timestamp is number &&
             isValidOptionalString('author', 0, 100) &&
             isValidOptionalString('category', 0, 100);
    }

    function isValidEvent(data) {
      return hasOnlyAllowedFields(['title', 'desc', 'startDate', 'endDate', 'location', 'zoomLink', 'posterUrl', 'timestamp']) &&
             data.title is map && 'en' in data.title && 'vi' in data.title &&
             data.title.en is string && data.title.vi is string &&
             data.desc is map && 'en' in data.desc && 'vi' in data.desc &&
             data.desc.en is string && data.desc.vi is string &&
             isValidString('startDate', 1, 50) &&
             isValidString('endDate', 1, 50) &&
             isValidString('location', 0, 500) &&
             (data.zoomLink == null || (data.zoomLink is string && data.zoomLink.size() <= 2000)) &&
             (data.posterUrl == null || (data.posterUrl is string && data.posterUrl.size() <= 2000)) &&
             data.timestamp is number;
    }

    function isValidUser(data) {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'role', 'createdAt']) &&
             isValidString('uid', 1, 200) &&
             isValidString('email', 1, 200) &&
             isValidString('displayName', 1, 200) &&
             isValidOptionalString('photoURL', 0, 2000) &&
             isValidString('role', 1, 50) &&
             isValidString('createdAt', 1, 100);
    }

    function isValidShift(data) {
      return hasOnlyAllowedFields(['name', 'dayOfWeek', 'startTime', 'durationHours', 'expectedVolunteers']) &&
             isValidString('name', 1, 100) &&
             data.dayOfWeek is number && data.dayOfWeek >= 0 && data.dayOfWeek <= 6 &&
             isValidString('startTime', 1, 20) &&
             data.durationHours is number && data.durationHours > 0 &&
             data.expectedVolunteers is number && data.expectedVolunteers >= 0;
    }

    function isValidShiftRegistration(data) {
      return hasOnlyAllowedFields(['shiftId', 'userId', 'userName', 'userEmail', 'date', 'status', 'timestamp']) &&
             isValidString('shiftId', 1, 200) &&
             isValidString('userId', 1, 200) &&
             isValidString('userName', 1, 200) &&
             isValidString('userEmail', 1, 200) &&
             isValidString('date', 1, 50) &&
             isValidString('status', 1, 50) && // We can allow Timestamp type or number, let's just bypass timestamp strict type check inside fields for now if it's serverTimestamp.
             (data.timestamp is number || data.timestamp is timestamp || data.timestamp == null);
    }

    function isValidWorshipSchedule(data) {
      return hasOnlyAllowedFields(['userId', 'userName', 'startTimeUTC', 'timezone', 'durationHours', 'timestamp', 'calendarId']) &&
             isValidString('userId', 1, 200) &&
             isValidString('userName', 1, 200) &&
             data.startTimeUTC is number &&
             isValidString('timezone', 1, 100) &&
             data.durationHours is number && data.durationHours > 0 &&
             (!('calendarId' in data) || isValidString('calendarId', 1, 200)) &&
             (data.timestamp is number || data.timestamp is timestamp || data.timestamp == null);
    }

    function isValidSermonGroup(data) {
      return hasOnlyAllowedFields(['name', 'description', 'customOrder', 'createdAt', 'updatedAt']) &&
             isValidString('name', 1, 200) &&
             isValidOptionalString('description', 0, 2000) &&
             (!('customOrder' in data) || data.customOrder is number) &&
             (!('createdAt' in data) || data.createdAt is number || data.createdAt == null || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is number || data.updatedAt == null || data.updatedAt is timestamp);
    }

    function isValidSermon(data) {
      return hasOnlyAllowedFields(['title', 'preacher', 'sermonDate', 'biblePassage', 'groupId', 'groupName', 'topics', 'description', 'fullInformation', 'language', 'documentUrl', 'downloadUrl', 'fileType', 'customOrder', 'status', 'createdAt', 'updatedAt']) &&
             isValidString('title', 1, 500) &&
             isValidString('preacher', 1, 200) &&
             isValidString('sermonDate', 1, 50) &&
             isValidString('status', 1, 20) && (data.status == 'published' || data.status == 'draft' || data.status == 'hidden') &&
             isValidOptionalString('biblePassage', 0, 500) &&
             isValidOptionalString('groupId', 0, 200) &&
             isValidOptionalString('groupName', 0, 200) &&
             isValidOptionalString('topics', 0, 500) &&
             isValidOptionalString('description', 0, 2000) &&
             isValidOptionalString('fullInformation', 0, 20000) &&
             isValidOptionalString('language', 0, 50) &&
             isValidOptionalString('documentUrl', 0, 2000) &&
             isValidOptionalString('downloadUrl', 0, 2000) &&
             isValidOptionalString('fileType', 0, 50) &&
             (!('customOrder' in data) || data.customOrder is number || data.customOrder == null) &&
             (!('createdAt' in data) || data.createdAt is number || data.createdAt == null || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is number || data.updatedAt == null || data.updatedAt is timestamp);
    }

    match /prayers/{prayerId} {
      // Publicly readable as this is a public prayer wall
      allow read: if true;
      
      // Publicly creatable, but strictly validated
      allow create: if isValidPrayer(request.resource.data) && request.resource.data.prayedCount == 0;
      
      // Anyone can increment the prayed count
      allow update: if isValidPrayerIncrement();
    }

    match /repentances/{repentanceId} {
      // Publicly readable as this is a public repenting corner
      allow read: if true;
      
      // Publicly creatable, but strictly validated
      allow create: if isValidRepentance(request.resource.data) && request.resource.data.graceCount == 0;
      
      // Anyone can increment the grace count
      allow update: if isValidGraceIncrement();
    }

    match /creations/{creationId} {
      // Publicly readable
      allow read: if true;
      
      // Publicly creatable, but strictly validated
      allow create: if isValidCreation(request.resource.data) && (!('amenCount' in request.resource.data) || request.resource.data.amenCount == 0);
      
      // Allow incrementing amenCount
      allow update: if isValidCreationIncrement();
    }

    match /journeyMedia/{mediaId} {
      // Publicly readable
      allow read: if true;
      
      // Only admin can create, and strictly validated
      allow create: if isAdmin() && isValidJourneyMedia(request.resource.data);
      
      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }
    
    match /events/{eventId} {
      // Publicly readable
      allow read: if true;
      
      // Only admin can create, and strictly validated
      allow create: if isAdmin() && isValidEvent(request.resource.data);
      
      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if true; // Allows anyone to read profiles (or we could limit to authed)
      allow create: if request.auth != null && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /shifts/{shiftId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidShift(request.resource.data));
    }

    match /shiftRegistrations/{registrationId} {
      allow read: if true;
      allow create: if request.auth != null && isValidShiftRegistration(request.resource.data);
      allow update: if isAdmin();
      allow delete: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
    }
    
    match /worshipCalendars/{calendarId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (isAdmin() || resource.data.createdBy == request.auth.uid);
    }
    
    match /worshipSchedule/{scheduleId} {
      allow read: if true;
      allow create: if request.auth != null && isValidWorshipSchedule(request.resource.data);
      allow update: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid) && isValidWorshipSchedule(request.resource.data);
      allow delete: if request.auth != null && (isAdmin() || resource.data.userId == request.auth.uid);
    }
    match /sermonGroups/{groupId} {
      allow read: if true;
      allow create, update, delete: if true;
    }

    match /sermons/{sermonId} {
      allow read: if true; // Public can read, UI filters out drafts/hidden
      allow create, update, delete: if true;
    }
  }
}

