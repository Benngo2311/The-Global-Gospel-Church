rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: prayers
    // Document ID: auto-generated
    // Fields:
    //   - text: string (required, max 2000 chars) - The prayer text
    //   - author: string (required, max 100 chars) - The author's name
    //   - email: string (optional, max 100 chars) - The author's email
    //   - phone: string (optional, max 50 chars) - The author's phone
    //   - prayedCount: number (required, >= 0) - Number of times prayed
    //   - timestamp: number (required) - Creation timestamp
    //
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isValidString(field, minLen, maxLen) {
      return request.resource.data[field] is string &&
        request.resource.data[field].size() >= minLen &&
        request.resource.data[field].size() <= maxLen;
    }
    
    function isValidOptionalString(field, minLen, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() >= minLen &&
              request.resource.data[field].size() <= maxLen);
    }
    
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    function isValidPrayer(data) {
      return hasOnlyAllowedFields(['text', 'author', 'email', 'phone', 'prayedCount', 'timestamp']) &&
             isValidString('text', 1, 2000) &&
             isValidString('author', 1, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('phone', 0, 50) &&
             data.prayedCount is number && data.prayedCount >= 0 &&
             data.timestamp is number;
    }
    
    function isValidPrayerIncrement() {
      // Only allow updating prayedCount by exactly +1 or -1, and ensure it doesn't go below 0
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedCount']) &&
             (request.resource.data.prayedCount == resource.data.prayedCount + 1 || 
              request.resource.data.prayedCount == resource.data.prayedCount - 1) &&
             request.resource.data.prayedCount >= 0;
    }

    function isValidRepentance(data) {
      return hasOnlyAllowedFields(['text', 'author', 'email', 'phone', 'graceCount', 'timestamp']) &&
             isValidString('text', 1, 2000) &&
             isValidString('author', 1, 100) &&
             isValidOptionalString('email', 0, 100) &&
             isValidOptionalString('phone', 0, 50) &&
             data.graceCount is number && data.graceCount >= 0 &&
             data.timestamp is number;
    }
    
    function isValidGraceIncrement() {
      // Only allow updating graceCount by exactly +1 or -1, and ensure it doesn't go below 0
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['graceCount']) &&
             (request.resource.data.graceCount == resource.data.graceCount + 1 || 
              request.resource.data.graceCount == resource.data.graceCount - 1) &&
             request.resource.data.graceCount >= 0;
    }

    function isValidCreation(data) {
      return hasOnlyAllowedFields(['category', 'title', 'author', 'content', 'audioUrl', 'imageUrl', 'videoUrl', 'timestamp', 'amenCount']) &&
             isValidString('category', 1, 50) &&
             (data.category == 'testimonies' || data.category == 'poems' || data.category == 'songs' || data.category == 'prophetic') &&
             isValidString('title', 1, 200) &&
             isValidString('author', 1, 100) &&
             isValidString('content', 1, 5000) &&
             isValidOptionalString('audioUrl', 0, 2000) &&
             isValidOptionalString('imageUrl', 0, 2000) &&
             isValidOptionalString('videoUrl', 0, 2000) &&
             data.timestamp is number &&
             (!('amenCount' in data) || (data.amenCount is number && data.amenCount >= 0));
    }

    function isValidCreationIncrement() {
      let oldAmenCount = 'amenCount' in resource.data ? resource.data.amenCount : 0;
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(['amenCount']) &&
             (request.resource.data.amenCount == oldAmenCount + 1 || 
              request.resource.data.amenCount == oldAmenCount - 1) &&
             request.resource.data.amenCount >= 0;
    }

    function isAdmin() {
      return request.auth != null && request.auth.token.email == "khoatruy123@gmail.com" && request.auth.token.email_verified == true;
    }

    function isValidJourneyMedia(data) {
      return hasOnlyAllowedFields(['url', 'type', 'description', 'year', 'date', 'isTimeline', 'timestamp', 'author']) &&
             isValidString('url', 1, 2000) &&
             (data.type == 'image' || data.type == 'video') &&
             isValidOptionalString('description', 0, 2000) &&
             (!('year' in data) || (data.year is number && data.year >= 1900 && data.year <= 2100)) &&
             isValidOptionalString('date', 0, 20) &&
             (!('isTimeline' in data) || data.isTimeline is bool) &&
             data.timestamp is number &&
             isValidOptionalString('author', 0, 100);
    }

    match /prayers/{prayerId} {
      // Publicly readable as this is a public prayer wall
      allow read: if true;
      
      // Publicly creatable, but strictly validated
      allow create: if isValidPrayer(request.resource.data) && request.resource.data.prayedCount == 0;
      
      // Anyone can increment the prayed count
      allow update: if isValidPrayerIncrement();
    }

    match /repentances/{repentanceId} {
      // Publicly readable as this is a public repenting corner
      allow read: if true;
      
      // Publicly creatable, but strictly validated
      allow create: if isValidRepentance(request.resource.data) && request.resource.data.graceCount == 0;
      
      // Anyone can increment the grace count
      allow update: if isValidGraceIncrement();
    }

    match /creations/{creationId} {
      // Publicly readable
      allow read: if true;
      
      // Publicly creatable, but strictly validated
      allow create: if isValidCreation(request.resource.data) && (!('amenCount' in request.resource.data) || request.resource.data.amenCount == 0);
      
      // Allow incrementing amenCount
      allow update: if isValidCreationIncrement();
    }

    match /journeyMedia/{mediaId} {
      // Publicly readable
      allow read: if true;
      
      // Only admin can create, and strictly validated
      allow create: if isAdmin() && isValidJourneyMedia(request.resource.data);
      
      // Only admin can update/delete
      allow update, delete: if isAdmin();
    }
  }
}
